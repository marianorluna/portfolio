RESEND_API_KEY=
CONTACT_TO=
CONTACT_FROM=Portfolio <onboarding@resend.dev>
#
# Contact API throttling (requests por IP por minuto)
CONTACT_RATE_LIMIT_MAX_PER_MINUTE=5

# Cloudflare Turnstile — clave pública en el cliente (widget)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Clave secreta solo en el servidor (verificación en /api/contact)
TURNSTILE_SECRET_KEY=
#
# Si ves el error 110200 en consola («Domain not authorized»): en Cloudflare Dashboard
# → Turnstile → tu sitio → Settings → Hostname management, añade cada host donde
# cargará el sitio (p. ej. localhost, 127.0.0.1 y tu dominio de producción).
